/* components/skeleton/skeleton.wxss */
.skeleton-wrap {
  padding: 24rpx;
}

/* 通用骨架线 */
.sk-line {
  height: 24rpx;
  background: linear-gradient(90deg, #1A1A2E 0%, #252540 50%, #1A1A2E 100%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: sk-shimmer 1.4s ease-in-out infinite;
}

.sk-title {
  height: 36rpx;
  width: 50%;
  margin-bottom: 24rpx;
}

.sk-text {
  width: 100%;
}

.sk-text.short {
  width: 60%;
}

/* 卡片骨架 */
.sk-card {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

/* 列表骨架 */
.sk-list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #1A1A2E;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.sk-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #1A1A2E 0%, #252540 50%, #1A1A2E 100%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

.sk-list-content {
  flex: 1;
}

.sk-list-content .sk-line {
  margin-bottom: 12rpx;
}

.sk-list-content .sk-line:last-child {
  margin-bottom: 0;
}

/* 首页概览骨架 */
.sk-dashboard-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.sk-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #1A1A2E 0%, #252540 50%, #1A1A2E 100%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

.sk-stats {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.sk-stats .sk-line {
  margin-bottom: 0;
  width: 100%;
}

.sk-actions {
  display: flex;
  justify-content: space-around;
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.sk-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.sk-action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #1A1A2E 0%, #252540 50%, #1A1A2E 100%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease-in-out infinite;
}

.sk-action .sk-line {
  margin-bottom: 0;
  width: 60rpx;
  height: 20rpx;
}

/* 排行榜骨架 */
.sk-rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #1A1A2E 0%, #252540 50%, #1A1A2E 100%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease-in-out infinite;
  flex-shrink: 0;
}

.sk-bar {
  height: 8rpx;
  width: 100%;
  background: linear-gradient(90deg, #1A1A2E 0%, #252540 50%, #1A1A2E 100%);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: sk-shimmer 1.4s ease-in-out infinite;
  margin-top: 12rpx;
}

/* 闪烁动画 */
@keyframes sk-shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}
