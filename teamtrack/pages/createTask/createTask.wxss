/* pages/createTask/createTask.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx;
}

.form-section {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-picker {
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-picker.placeholder {
  color: #666;
}

.placeholder {
  color: #666;
}

.form-hint {
  display: block;
  margin-top: 12rpx;
  padding-left: 8rpx;
}

.text-xs { font-size: 22rpx; }
.text-secondary { color: #A0A0B0; }

.picker-arrow {
  color: #A0A0B0;
  font-size: 32rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  background: #252540;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #A0A0B0;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.category-item.active {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  color: #FFFFFF;
  border-color: transparent;
}

.points-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.points-item {
  flex: 1;
  min-width: 120rpx;
  text-align: center;
  padding: 16rpx;
  background: #252540;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #A0A0B0;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.points-item.active {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  color: #FFFFFF;
  border-color: transparent;
  font-weight: 600;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 8rpx;
}

.form-actions button {
  flex: 1;
}