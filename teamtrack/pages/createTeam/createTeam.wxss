/* pages/createTeam/createTeam.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx;
}

.form-section {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-picker {
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.form-picker.placeholder {
  color: #666;
}

.picker-arrow {
  color: #A0A0B0;
  font-size: 32rpx;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 8rpx;
}

.form-actions button {
  flex: 1;
}