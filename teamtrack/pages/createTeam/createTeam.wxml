<!--pages/createTeam/createTeam.wxml-->
<view class="page">
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">队伍名称</text>
      <input class="form-input" placeholder="如：智创未来" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>

    <view class="form-item">
      <text class="form-label">参赛赛事</text>
      <picker mode="selector" range="{{competitions}}" value="{{compIndex}}" bindchange="onCompChange">
        <view class="form-picker {{form.competition ? '' : 'placeholder'}}">
          {{form.competition || '请选择参赛赛事'}}
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">项目描述</text>
      <textarea class="form-textarea" placeholder="简要描述你的参赛项目" value="{{form.description}}" bindinput="onInput" data-field="description" />
    </view>

    <view class="form-item">
      <text class="form-label">截止日期</text>
      <picker mode="date" value="{{form.deadline}}" start="{{today}}" bindchange="onDateChange">
        <view class="form-picker {{form.deadline ? '' : 'placeholder'}}">
          {{form.deadline || '请选择截止日期'}}
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="form-actions">
    <button class="btn-secondary" bindtap="onCancel">取消</button>
    <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}">创建队伍</button>
  </view>
</view>