/* pages/myStats/myStats.wxss */
.page {
  padding: 24rpx;
  min-height: 100vh;
}

/* 汇总卡片 */
.summary-card {
  background: linear-gradient(135deg, #1A1A2E 0%, #252540 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 107, 53, 0.15);
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 28rpx;
}

.summary-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 12rpx 0;
}

.ss-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.ss-num {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.ss-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.08);
}

.summary-meta {
  text-align: center;
  margin-top: 24rpx;
}

/* 区块标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #A0A0B0;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* 队伍统计卡片 */
.team-stat-card {
  background: #1A1A2E;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.tsc-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.tsc-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tsc-info {
  flex: 1;
  min-width: 0;
}

.tsc-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.tsc-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tsc-competition {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tsc-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 14rpx;
  padding: 24rpx 0;
}

.tsc-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.tsc-stat-num {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.tsc-footer {
  margin-top: 20rpx;
  text-align: right;
}

.tsc-link {
  font-size: 24rpx;
  color: #FF6B35;
  display: inline-block;
}

/* 空状态 / 加载 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 12rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #FFFFFF;
}

.empty-desc {
  font-size: 26rpx;
}

.loading-state {
  text-align: center;
  padding: 80rpx 0;
}

.bottom-space {
  height: 40rpx;
}
