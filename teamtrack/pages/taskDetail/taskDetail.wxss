/* pages/taskDetail/taskDetail.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.detail-header {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.detail-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
}

.ml-md {
  margin-left: 24rpx;
}

.detail-section {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #A0A0B0;
  margin-bottom: 20rpx;
}

.detail-content {
  font-size: 30rpx;
  color: #FFFFFF;
  line-height: 1.8;
}

.deadline-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #252540;
  border-radius: 16rpx;
  padding: 28rpx;
}

.deadline-card.urgent {
  background: rgba(255, 71, 87, 0.1);
  border: 1rpx solid rgba(255, 71, 87, 0.3);
}

.deadline-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.deadline-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.deadline-countdown {
  font-size: 28rpx;
  font-weight: 600;
}

.deadline-icon {
  font-size: 48rpx;
}

.assignee-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
}

.assignee-avatar-lg {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #1E90FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.assignee-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 4rpx;
}

.no-assignee {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 0;
}

.claim-btn {
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.deliverable-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.deliverable-item:last-child {
  border-bottom: none;
}

.del-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #FFFFFF;
  flex-shrink: 0;
}

.del-info {
  overflow: hidden;
}

.del-name {
  font-size: 28rpx;
  color: #FFFFFF;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-mini {
  text-align: center;
  padding: 32rpx 0;
  color: #A0A0B0;
  font-size: 26rpx;
}

.detail-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(15, 15, 26, 0.95);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.detail-actions button {
  flex: 1;
}

.completed-badge {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: rgba(0, 212, 170, 0.15);
  border-radius: 16rpx;
  color: #00D4AA;
  font-size: 30rpx;
  font-weight: 600;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}