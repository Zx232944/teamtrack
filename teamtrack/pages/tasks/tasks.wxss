/* pages/tasks/tasks.wxss */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.filter-bar {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  background: #0F0F1A;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #1A1A2E;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #A0A0B0;
  transition: all 0.25s ease;
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-item.active {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  color: #FFFFFF;
}

.filter-count {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
}

.filter-item.active .filter-count {
  background: rgba(255, 255, 255, 0.3);
}

.task-list {
  flex: 1;
  padding: 16rpx 24rpx;
}

.task-card {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  overflow: hidden;
  transition: transform 0.15s ease, background 0.15s ease;
  animation: fadeInUp 0.3s ease-out;
}

.task-card:active {
  transform: scale(0.98);
  background: #252540;
}

.task-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
}

.task-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.task-card-desc {
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.task-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.task-footer-left {
  display: flex;
  align-items: center;
}

.task-assignee {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.assignee-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #1E90FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.task-footer-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.task-points {
  font-size: 28rpx;
}

.task-deadline {
  font-size: 22rpx;
}

.task-claim-btn {
  margin-top: 20rpx;
  padding: 20rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

/* 空状态 */
.empty-state {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-btn {
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.5);
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
}

.bottom-space {
  height: 120rpx;
}