<!--pages/tasks/tasks.wxml-->
<view class="page">
  <!-- 未登录提示 -->
  <view wx:if="{{!isLoggedIn}}" class="login-prompt">
    <view class="login-avatar-placeholder">👤</view>
    <text class="login-title">登录后查看任务</text>
    <text class="login-desc text-secondary">请先登录以使用赛队管家</text>
    <navigator url="/pages/profile/profile" open-type="switchTab" class="btn-primary login-btn">去登录</navigator>
  </view>

  <block wx:else>
    <!-- 团队切换条 -->
    <view class="team-switcher">
      <view class="team-chip-manage" bindtap="goTeamsPage">
        <text class="team-chip-manage-icon">≡</text>
        <text>管理</text>
      </view>
      <scroll-view scroll-x class="team-switcher-scroll" enhanced show-scrollbar="{{false}}">
        <view wx:for="{{teams}}" wx:key="_id"
          class="team-chip {{item.isActive ? 'active' : ''}}"
          bindtap="onSwitchTeam" data-id="{{item._id}}">
          <view class="team-chip-dot"></view>
          <text>{{item.name}}</text>
          <text wx:if="{{item.isCaptain}}" class="team-chip-captain">队长</text>
        </view>
      </scroll-view>
    </view>

  <!-- 筛选标签 -->
  <view class="filter-bar" wx:if="{{hasTeams}}">
    <view class="filter-item {{currentFilter === 'all' ? 'active' : ''}}" bindtap="onFilter" data-filter="all">
      <text>全部</text>
      <text class="filter-count">{{allCount}}</text>
    </view>
    <view class="filter-item {{currentFilter === 'pending' ? 'active' : ''}}" bindtap="onFilter" data-filter="pending">
      <text>待领取</text>
      <text class="filter-count">{{pendingCount}}</text>
    </view>
    <view class="filter-item {{currentFilter === 'in_progress' ? 'active' : ''}}" bindtap="onFilter" data-filter="in_progress">
      <text>进行中</text>
      <text class="filter-count">{{inProgressCount}}</text>
    </view>
    <view class="filter-item {{currentFilter === 'completed' ? 'active' : ''}}" bindtap="onFilter" data-filter="completed">
      <text>已完成</text>
      <text class="filter-count">{{completedCount}}</text>
    </view>
  </view>

  <!-- 任务列表 -->
  <scroll-view scroll-y class="task-list" refresher-enabled bindrefresherrefresh="onRefresh" refresher-triggered="{{refreshing}}">
    <!-- 骨架屏 -->
    <skeleton wx:if="{{loading && hasTeams}}" type="card" count="{{[1,2,3,4]}}" loading="{{loading}}" />

    <view wx:if="{{!loading && filteredTasks.length > 0}}">
      <view wx:for="{{filteredTasks}}" wx:key="_id" class="task-card" bindtap="goTaskDetail" data-id="{{item._id}}">
        <view class="task-card-header">
          <view class="task-category-tag tag tag-blue">{{item.category}}</view>
          <view class="tag {{item.statusClass}}">{{item.statusText}}</view>
        </view>

        <view class="task-card-title">{{item.title}}</view>
        <view class="task-card-desc text-sm text-secondary">{{item.description}}</view>

        <view class="task-card-footer">
          <view class="task-footer-left">
            <view class="task-assignee">
              <view class="assignee-avatar">{{item.assigneeName ? item.assigneeName[0] : '?'}}</view>
              <text class="text-sm text-secondary">{{item.assigneeName || '待领取'}}</text>
            </view>
          </view>
          <view class="task-footer-right">
            <text class="task-points text-orange font-bold">{{item.points}}分</text>
            <text class="task-deadline text-xs {{item.urgent ? 'text-red' : 'text-secondary'}}">{{item.countdownText}}</text>
          </view>
        </view>

        <!-- 抢单按钮 -->
        <view wx:if="{{item.status === 'pending'}}" class="task-claim-btn" catchtap="onClaimTask" data-id="{{item._id}}" data-index="{{index}}">
          立即抢单
        </view>
      </view>
    </view>

    <!-- 无团队空状态 -->
    <view wx:if="{{!hasTeams}}" class="empty-state">
      <text class="empty-icon">👥</text>
      <text class="empty-text">还没有团队</text>
      <view class="empty-btn" bindtap="goTeamsPage">去管理团队</view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{hasTeams && filteredTasks.length === 0 && !loading}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无任务</text>
      <view class="empty-btn" bindtap="goCreateTask">发布新任务</view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <!-- 悬浮发布按钮 -->
  <view class="fab-btn" bindtap="goCreateTask">
    <text class="fab-icon">+</text>
  </view>
  </block>
</view>