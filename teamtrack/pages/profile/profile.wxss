/* pages/profile/profile.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 32rpx;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #1E90FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.profile-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 0 24rpx;
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
}

.ps-arrow {
  position: absolute;
  right: 24rpx;
  font-size: 32rpx;
  color: #5A5A6E;
}

.ps-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.ps-num {
  font-size: 44rpx;
  font-weight: 700;
}

.ps-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.08);
}

.menu-section {
  margin: 24rpx;
  background: #1A1A2E;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.menu-title {
  font-size: 26rpx;
  color: #A0A0B0;
  padding: 20rpx 28rpx 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #FFFFFF;
}

.menu-count {
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.06);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.menu-arrow {
  font-size: 36rpx;
}

.product-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 48rpx;
}

.mt-sm {
  margin-top: 8rpx;
}

/* 登录引导 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.login-avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #1A1A2E;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 28rpx;
  margin-bottom: 48rpx;
}

.login-btn {
  width: 60%;
}

/* 注册流程卡片 */
.register-prompt {
  padding-top: 120rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.register-card {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255, 107, 53, 0.2);
}

.register-step-badge {
  font-size: 22rpx;
  color: #FF6B35;
  background: rgba(255, 107, 53, 0.15);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.register-title {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.register-desc {
  font-size: 26rpx;
  margin-bottom: 32rpx;
  text-align: center;
  line-height: 1.5;
}

.register-skip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #A0A0B0;
  padding: 12rpx 24rpx;
}

.register-input {
  width: 100%;
  background: #252540;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.edit-icon {
  font-size: 28rpx;
  color: #A0A0B0;
  margin-left: 8rpx;
}