<!--pages/profile/profile.wxml-->
<view class="page">
  <!-- 未登录状态 -->
  <block wx:if="{{!isLoggedIn}}">
    <!-- 登录入口（仅在未进入注册流程时显示） -->
    <view class="login-prompt" wx:if="{{!registerStep}}">
      <view class="login-avatar-placeholder">👤</view>
      <text class="login-title">登录赛队管家</text>
      <text class="login-desc text-secondary">首次登录需授权手机号并设置昵称</text>
      <button class="btn-primary login-btn" bindtap="onLogin">微信登录</button>
    </view>

    <!-- 注册流程：获取手机号 -->
    <view class="register-prompt" wx:if="{{registerStep === 'phone'}}">
      <view class="register-card">
        <view class="register-step-badge">第 1 / 2 步</view>
        <text class="register-title">欢迎新用户</text>
        <text class="register-desc text-secondary">请先授权手机号完成注册（用于团队内联系）</text>
        <button class="btn-primary login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
          授权手机号
        </button>
        <view class="register-skip" bindtap="onSkipPhone">暂不授权，跳过</view>
      </view>
    </view>

    <!-- 注册流程：设置昵称 -->
    <view class="register-prompt" wx:if="{{registerStep === 'nickName'}}">
      <view class="register-card">
        <view class="register-step-badge">第 2 / 2 步</view>
        <text class="register-title">设置昵称</text>
        <text class="register-desc text-secondary">请输入你在团队中的昵称，方便队友认出你</text>
        <input class="register-input" placeholder="请输入昵称" value="{{tempNickName}}" bindinput="onNickNameInput" maxlength="20" focus="{{true}}" />
        <button class="btn-primary login-btn" bindtap="onSubmitRegister">完成注册</button>
      </view>
    </view>
  </block>

  <!-- 已登录 -->
  <block wx:else>
    <!-- 个人信息卡片 -->
    <view class="profile-header">
      <view class="profile-avatar" bindtap="onEditNickName">{{user.nickName ? user.nickName[0] : '我'}}</view>
      <view class="profile-name" bindtap="onEditNickName">{{user.nickName || '点击设置昵称'}}
        <text class="edit-icon">✎</text>
      </view>
    </view>

    <!-- 统计概览（所有团队汇总，点击查看明细） -->
    <view class="profile-stats" bindtap="goMyStats">
      <view class="ps-item">
        <text class="ps-num text-orange">{{user.contribution || 0}}</text>
        <text class="ps-label text-xs text-secondary">累计贡献</text>
      </view>
      <view class="ps-divider"></view>
      <view class="ps-item">
        <text class="ps-num text-green">{{user.completedTasks || 0}}</text>
        <text class="ps-label text-xs text-secondary">已完成</text>
      </view>
      <view class="ps-divider"></view>
      <view class="ps-item">
        <text class="ps-num text-blue">{{user.ongoingTasks || 0}}</text>
        <text class="ps-label text-xs text-secondary">进行中</text>
      </view>
      <text class="ps-arrow text-secondary">›</text>
    </view>

    <!-- 我的任务 -->
    <view class="menu-section">
      <view class="menu-title">我的任务</view>
      <view class="menu-item" bindtap="goMyTasks">
        <view class="menu-icon" style="background: rgba(30, 144, 255, 0.15);">
          <text style="color: #1E90FF;">📝</text>
        </view>
        <text class="menu-text flex-1">任务中心</text>
        <text class="menu-arrow text-secondary">›</text>
      </view>
    </view>

    <!-- 团队管理 -->
    <view class="menu-section">
      <view class="menu-title">团队管理</view>
      <view class="menu-item" bindtap="goTeams">
        <view class="menu-icon" style="background: rgba(30, 144, 255, 0.15);">
          <text style="color: #1E90FF;">☰</text>
        </view>
        <text class="menu-text flex-1">我的团队</text>
        <text class="menu-arrow text-secondary">›</text>
      </view>
      <view class="menu-item" bindtap="goTeam">
        <view class="menu-icon" style="background: rgba(255, 107, 53, 0.15);">
          <text style="color: #FF6B35;">👥</text>
        </view>
        <text class="menu-text flex-1">当前团队详情</text>
        <text class="menu-arrow text-secondary">›</text>
      </view>
    </view>

    <!-- 其他设置 -->
    <view class="menu-section">
      <view class="menu-title">设置</view>
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon" style="background: rgba(30, 144, 255, 0.15);">
          <text style="color: #1E90FF;">ℹ</text>
        </view>
        <text class="menu-text flex-1">关于赛队管家</text>
        <text class="menu-arrow text-secondary">›</text>
      </view>
      <view class="menu-item" bindtap="showHelp">
        <view class="menu-icon" style="background: rgba(0, 212, 170, 0.15);">
          <text style="color: #00D4AA;">?</text>
        </view>
        <text class="menu-text flex-1">使用帮助</text>
        <text class="menu-arrow text-secondary">›</text>
      </view>
      <view class="menu-item" bindtap="onLogout">
        <view class="menu-icon" style="background: rgba(255, 71, 87, 0.15);">
          <text style="color: #FF4757;">⏻</text>
        </view>
        <text class="menu-text flex-1">退出登录</text>
        <text class="menu-arrow text-secondary">›</text>
      </view>
    </view>

    <!-- 产品信息 -->
    <view class="product-info">
      <text class="text-xs text-secondary">赛队管家 TeamTrack v1.0.0</text>
      <text class="text-xs text-secondary mt-sm">让竞赛协作更高效 · Powered by 微信云开发</text>
    </view>
  </block>
</view>