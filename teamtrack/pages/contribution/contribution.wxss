/* pages/contribution/contribution.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.contribution-header {
  padding: 24rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #1E90FF);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.user-score {
  text-align: right;
  display: flex;
  flex-direction: column;
}

.score-num {
  font-size: 48rpx;
  font-weight: 700;
}

.score-label {
  margin-top: 4rpx;
}

.stats-cards {
  display: flex;
  gap: 20rpx;
}

.stat-card-mini {
  flex: 1;
  background: #1A1A2E;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.stat-text {
  font-size: 24rpx;
}

/* 区块 */
.section {
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* 图表 */
.chart-card {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.chart-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 300rpx;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.chart-bar-bg {
  width: 40rpx;
  height: 80%;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.chart-bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #FF6B35, #FF8C5A);
  border-radius: 8rpx;
  transition: height 0.5s ease;
}

.chart-bar-value {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.chart-bar-label {
  margin-top: 4rpx;
  font-size: 20rpx;
}

/* 排行榜 */
.ranking-full {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.ranking-full-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.ranking-full-item:last-child {
  border-bottom: none;
}

.ranking-full-item.is-me {
  background: rgba(255, 107, 53, 0.05);
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 8rpx -8rpx;
}

.rank-num-box {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.rank-emoji {
  font-size: 36rpx;
}

.rank-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #A0A0B0;
}

.rank-user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1E90FF, #4169E1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  flex-shrink: 0;
}

.rank-user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rank-user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.rank-user-score {
  font-size: 32rpx;
}

.rank-progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 4rpx;
  overflow: hidden;
}

.rank-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35, #FF8C5A);
  border-radius: 4rpx;
}

/* 交付物列表 */
.deliverable-list {
  background: #1A1A2E;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.deliverable-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.deliverable-item:active {
  opacity: 0.7;
}

.deliverable-item:last-child {
  border-bottom: none;
}

.del-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  flex-shrink: 0;
}

.del-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.del-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.del-meta {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.del-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.del-action {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 107, 53, 0.1);
  border-radius: 16rpx;
}

.bottom-space {
  height: 40rpx;
}